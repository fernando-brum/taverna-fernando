<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MarmitaTech - Secret Registration</title>
    <link href="https://fonts.googleapis.com/css2?family=Racing+Sans+One&family=Teko:wght@400;600&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body { 
            font-family: 'Teko', sans-serif;
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh;
            background: radial-gradient(circle at center, #2e1a1a 0%, #000000 100%);
            overflow: hidden;
            position: relative;
            color: #fff;
        }

        body::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 800px;
            height: 800px;
            background: radial-gradient(circle, rgba(255, 0, 85, 0.15) 0%, transparent 60%);
            transform: translate(-50%, -50%);
            z-index: 0;
        }

        form { 
            z-index: 1;
            background: 
                linear-gradient(27deg, #151515 5px, transparent 5px) 0 5px,
                linear-gradient(207deg, #151515 5px, transparent 5px) 10px 0px,
                linear-gradient(27deg, #222 5px, transparent 5px) 0px 10px,
                linear-gradient(207deg, #222 5px, transparent 5px) 10px 5px,
                linear-gradient(90deg, #1b1b1b 10px, transparent 10px),
                linear-gradient(#1d1d1d 25%, #1a1a1a 25%, #1a1a1a 50%, transparent 50%, transparent 75%, #242424 75%, #242424 100%);
            background-size: 20px 20px;
            background-color: #131313;
            
            border: 2px solid #ff0055;
            box-shadow: 0 0 20px #ff0055, inset 0 0 20px rgba(255, 0, 85, 0.3);
            
            padding: 40px 40px 50px 50px;
            border-radius: 12px; 
            width: 100%;
            max-width: 400px;
            text-align: center;
            position: relative;
        }

        form::after {
            content: '';
            position: absolute;
            top: 0;
            left: 20px;
            width: 8px;
            height: 100%;
            background: #ff0055;
            box-shadow: 0 0 15px #ff0055;
            transform: skewX(-15deg);
        }

        h2 {
            font-family: 'Racing Sans One', cursive;
            color: #fff; 
            margin-bottom: 30px;
            font-size: 38px;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-shadow: 0 0 10px #ff0055, 0 0 20px #ff0055, 4px 4px 0 #000;
            transform: skewX(-10deg);
        }

        .input-group {
            position: relative;
            margin-bottom: 20px;
            transform: skewX(-5deg);
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 15px 15px 15px 20px;
            background: rgba(10, 10, 10, 0.9);
            border: 1px solid #333;
            border-bottom: 3px solid #ff0055;
            color: #ff0055;
            font-family: 'Teko', sans-serif;
            font-size: 22px;
            letter-spacing: 1px;
            transition: all 0.3s ease; 
            outline: none;
            box-shadow: inset 0 2px 5px rgba(0,0,0,0.8);
        }

        input::placeholder {
            color: rgba(255, 0, 85, 0.5);
            font-style: italic;
            text-transform: uppercase;
        }

        input:focus {
            border-color: #ff0055;
            background: rgba(255, 0, 85, 0.1);
            box-shadow: 0 0 15px rgba(255, 0, 85, 0.4), inset 0 2px 5px rgba(0,0,0,0.8);
            transform: scale(1.02);
        }

        button {
            width: 100%;
            padding: 15px;
            background: linear-gradient(90deg, #ff0055, #b3003c);
            color: #fff;
            border: none;
            font-family: 'Racing Sans One', cursive;
            font-size: 24px;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.2s ease;
            margin-top: 15px;
            transform: skewX(-5deg);
            box-shadow: 0 0 15px #ff0055;
            position: relative;
            overflow: hidden;
        }

        button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent);
            transition: all 0.4s ease;
        }

        button:hover {
            transform: skewX(-5deg) scale(1.05);
            box-shadow: 0 0 25px #ff0055, 0 0 40px #ff0055;
        }

        button:hover::before {
            left: 100%;
            transition: all 0.4s ease;
        }

        button:active {
            transform: skewX(-5deg) scale(0.95);
        }

        .decal {
            position: absolute;
            font-family: 'Racing Sans One', cursive;
            color: rgba(255, 255, 255, 0.03);
            font-size: 180px;
            z-index: 0;
            pointer-events: none;
            transform: rotate(-15deg);
            white-space: nowrap;
        }

        .decal-1 { top: -40px; left: -150px; }
        .decal-2 { bottom: -60px; right: -100px; }

    </style>
</head>
<body>
    <div class="decal decal-1">NEW</div>
    <div class="decal decal-2">DRIVER</div>
    <form action="/register" method="POST">
        <h2>Novo Piloto</h2>
        <div class="input-group">
            <input type="text" name="username" placeholder="Rider_Name" required>
        </div>
        <div class="input-group">
            <input type="password" name="password" placeholder="Ignition_Key" required>
        </div>
        <button type="submit">Cadastrar</button>
        <a href="/" style="display: block; margin-top: 20px; color: #ff0055; font-family: 'Teko'; text-decoration: none; font-size: 20px;">&laquo; Voltar pra Garagem</a>
    </form>
</body>
</html>
