<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>taverna-fernando - Kanban</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: #021a2e;
            padding: 24px;
            color: #fff;
            overflow-x: hidden;
        }

        /* ── Fundo ── */
        .bg {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background:
                radial-gradient(ellipse 80% 60% at 10% 20%, #0a4d6e 0%, transparent 55%),
                radial-gradient(ellipse 60% 70% at 90% 80%, #0d7a50 0%, transparent 55%),
                radial-gradient(ellipse 50% 60% at 50% 50%, #2a0a5e 0%, transparent 60%),
                linear-gradient(160deg, #021a2e 0%, #0d0520 100%);
        }
        .grid-lines {
            position: fixed; inset: 0; z-index: 0; pointer-events: none;
            background-image: linear-gradient(rgba(0,200,255,0.04) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(0,200,255,0.04) 1px, transparent 1px);
            background-size: 48px 48px;
        }
        .orb {
            position: fixed; border-radius: 50%; filter: blur(70px); opacity: 0.2;
            animation: orbFloat linear infinite; z-index: 0; pointer-events: none;
        }
        .orb-1 { width:500px;height:500px;background:radial-gradient(#00d4ff,#0066cc);top:-150px;left:-150px;animation-duration:22s; }
        .orb-2 { width:350px;height:350px;background:radial-gradient(#00ff99,#00aa66);bottom:-100px;right:-100px;animation-duration:28s;animation-delay:-12s; }
        .orb-3 { width:280px;height:280px;background:radial-gradient(#aa44ff,#6600cc);top:40%;left:40%;animation-duration:18s;animation-delay:-6s; }
        @keyframes orbFloat {
            0%,100%{transform:translate(0,0)} 33%{transform:translate(40px,-50px)} 66%{transform:translate(-30px,30px)}
        }

        /* ── Layout ── */
        .content { position: relative; z-index: 1; display:flex; flex-direction:column; height:calc(100vh - 48px); }

        /* ── Header ── */
        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px; padding: 14px 24px; flex-shrink: 0;
            background: linear-gradient(135deg,rgba(255,255,255,0.13),rgba(255,255,255,0.05));
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 20px;
            backdrop-filter: blur(20px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.3);
            position: relative; z-index: 20;
        }

        /* ── Dropdown Exportar ── */
        .export-wrap { position:relative; display:inline-block; }
        .btn-export {
            display:inline-flex; align-items:center; gap:6px; padding:7px 14px;
            border-radius:12px; font-size:13px; font-weight:600; cursor:pointer;
            background:linear-gradient(135deg,rgba(42,245,176,0.2),rgba(0,180,120,0.1));
            border:1px solid rgba(42,245,176,0.35); color:#7ae8c8;
            transition:all 0.2s; box-shadow:inset 0 1px 0 rgba(255,255,255,0.1);
            user-select:none;
        }
        .btn-export:hover { background:linear-gradient(135deg,rgba(42,245,176,0.3),rgba(0,180,120,0.2)); color:#fff; transform:translateY(-1px); }
        .btn-export .chevron { font-size:10px; transition:transform 0.2s; }
        .btn-export.open .chevron { transform:rotate(180deg); }
        .export-menu {
            display:none; position:absolute; top:calc(100% + 8px); right:0;
            min-width:168px; z-index:60;
            background:linear-gradient(160deg,rgba(10,28,50,0.97),rgba(4,20,36,0.98));
            border:1px solid rgba(42,245,176,0.25); border-radius:14px;
            backdrop-filter:blur(20px);
            box-shadow:0 12px 40px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.1);
            overflow:hidden; animation:menuIn 0.18s cubic-bezier(0.16,1,0.3,1) both;
        }
        @keyframes menuIn { from{opacity:0;transform:translateY(-6px) scale(0.97)} to{opacity:1;transform:translateY(0) scale(1)} }
        .export-menu.open { display:block; }
        .export-option {
            display:flex; align-items:center; gap:10px; padding:11px 16px;
            color:rgba(255,255,255,0.75); text-decoration:none;
            font-size:13px; font-weight:500; transition:background 0.15s, color 0.15s;
        }
        .export-option:hover { background:rgba(42,245,176,0.1); color:#7ae8c8; }
        .export-option + .export-option { border-top:1px solid rgba(255,255,255,0.07); }
        .header-left { display:flex; align-items:center; gap:16px; }
        .header h1 {
            font-size: 20px; font-weight: 700;
            background: linear-gradient(135deg,#fff 0%,#c4aaff 50%,#7ae8c8 100%);
            -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
        }
        .logo { height: 48px; filter: drop-shadow(0 2px 12px rgba(0,200,255,0.5)); }
        .nav-dash {
            display:inline-flex; align-items:center; gap:6px; padding:7px 16px;
            border-radius:12px; font-size:13px; font-weight:600;
            background:rgba(255,255,255,0.09); border:1px solid rgba(255,255,255,0.2);
            color:rgba(255,255,255,0.75); text-decoration:none; transition:all 0.2s;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.12);
        }
        .nav-dash:hover { background:rgba(255,255,255,0.16); color:#fff; transform:translateY(-1px); }

        /* ── Board ── */
        .kanban-board {
            display: flex; gap: 16px;
            flex: 1; overflow-x: auto; overflow-y: hidden;
            padding-bottom: 8px;
        }
        .kanban-board::-webkit-scrollbar { height: 6px; }
        .kanban-board::-webkit-scrollbar-track { background: rgba(255,255,255,0.04); border-radius: 3px; }
        .kanban-board::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 3px; }

        /* ── Colunas ── */
        .kanban-col {
            flex: 0 0 280px;
            display: flex; flex-direction: column;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 20px;
            overflow: hidden;
            backdrop-filter: blur(12px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.25);
        }

        .col-header {
            padding: 14px 16px; flex-shrink: 0;
            display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            cursor: pointer; user-select: none;
        }
        .col-icon { font-size: 18px; }
        .col-title { font-size: 14px; font-weight: 700; flex: 1; letter-spacing: 0.3px; }
        .col-count {
            font-size: 12px; font-weight: 700; padding: 2px 10px;
            border-radius: 20px; background: rgba(0,0,0,0.25);
            border: 1px solid rgba(255,255,255,0.15);
        }
        .col-toggle {
            background: none; border: none; cursor: pointer; padding: 4px 6px;
            color: rgba(255,255,255,0.45); border-radius: 8px; transition: all 0.2s;
            display: flex; align-items: center; justify-content: center;
        }
        .col-toggle:hover { background: rgba(255,255,255,0.1); color: #fff; }
        .col-toggle .chevron {
            display: inline-block; font-size: 11px; line-height: 1;
            transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
        }
        .kanban-col.collapsed .col-toggle .chevron { transform: rotate(-90deg); }

        /* Cores por status */
        .col-aberto   { background: linear-gradient(135deg, rgba(0,160,220,0.3), rgba(0,100,180,0.15)); }
        .col-cozinha  { background: linear-gradient(135deg, rgba(255,160,0,0.3),  rgba(200,100,0,0.15)); }
        .col-entrega  { background: linear-gradient(135deg, rgba(160,80,255,0.3), rgba(100,40,200,0.15)); }
        .col-entregue { background: linear-gradient(135deg, rgba(0,200,120,0.3),  rgba(0,140,80,0.15));  }

        .col-aberto   .col-title { color: #7dd8f8; }
        .col-cozinha  .col-title { color: #ffc766; }
        .col-entrega  .col-title { color: #c4aaff; }
        .col-entregue .col-title { color: #7ae8c8; }

        /* ── Cards dentro da coluna ── */
        .cards {
            flex: 1; overflow-y: auto; padding: 10px;
            display: flex; flex-direction: column; gap: 10px;
            max-height: 800px;
            transition: max-height 0.35s cubic-bezier(0.16,1,0.3,1),
                        opacity 0.25s ease,
                        padding 0.3s ease;
        }
        .cards::-webkit-scrollbar { width: 4px; }
        .cards::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 2px; }
        .kanban-col.collapsed .cards {
            max-height: 0; opacity: 0;
            padding-top: 0; padding-bottom: 0;
            overflow: hidden;
        }

        .empty-col {
            text-align: center; padding: 32px 12px;
            font-size: 12px; color: rgba(255,255,255,0.25); letter-spacing: 0.5px;
        }

        /* ── Kanban Card ── */
        .kcard {
            background: linear-gradient(145deg, rgba(255,255,255,0.12), rgba(255,255,255,0.05));
            border: 1px solid rgba(255,255,255,0.18);
            border-radius: 14px; padding: 14px;
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.25);
            position: relative; overflow: hidden;
            transition: opacity 0.35s ease, transform 0.35s ease, box-shadow 0.2s;
        }
        .kcard::before {
            content:''; position:absolute; top:0;left:0;right:0;height:35%;
            background:linear-gradient(180deg,rgba(255,255,255,0.1),transparent);
            border-radius:14px 14px 0 0; pointer-events:none;
        }
        .kcard:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.3); transform:translateY(-2px); }

        .kcard-id {
            font-size: 10px; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1px; color: rgba(255,255,255,0.35); margin-bottom: 4px;
        }
        .kcard-name { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 8px; }
        .kcard-size {
            display: inline-block; font-size: 11px; font-weight: 600; padding: 3px 10px;
            border-radius: 20px; margin-bottom: 8px;
            background: rgba(0,180,200,0.2); border: 1px solid rgba(0,200,220,0.35);
            color: #7ae8f8;
        }
        .kcard-items {
            font-size: 11px; color: rgba(255,255,255,0.5); line-height: 1.5;
            margin-bottom: 12px; min-height: 16px;
        }

        /* Botão avançar */
        .btn-advance {
            width: 100%; padding: 8px; border: none; border-radius: 10px;
            font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700;
            cursor: pointer; position: relative; overflow: hidden;
            transition: all 0.2s; letter-spacing: 0.3px;
        }
        .btn-advance::before {
            content:''; position:absolute; top:0;left:0;right:0;height:50%;
            background:linear-gradient(180deg,rgba(255,255,255,0.35),transparent);
            border-radius:10px 10px 0 0;
        }
        .kanban-col[data-status="Aberto"]  .btn-advance { background:linear-gradient(180deg,#29d4f5,#009ec0); color:#002030; box-shadow:0 3px 12px rgba(0,160,200,0.4); }
        .kanban-col[data-status="Cozinha"] .btn-advance { background:linear-gradient(180deg,#ffb830,#d07800); color:#2a1800; box-shadow:0 3px 12px rgba(200,120,0,0.4); }
        .kanban-col[data-status="Entrega"] .btn-advance { background:linear-gradient(180deg,#b870ff,#7020cc); color:#1a0040; box-shadow:0 3px 12px rgba(140,60,220,0.4); }
        .btn-advance:hover { filter:brightness(1.1); transform:translateY(-1px); }
        .btn-advance:active { transform:translateY(1px); filter:brightness(0.93); }

        /* Info entregue */
        .kcard-delivered {
            font-size: 11px; margin-top: 4px;
            color: rgba(255,255,255,0.4); line-height: 1.6;
        }
        .kcard-delivered strong { color: #7ae8c8; }

        /* ── Modal entrega ── */
        .modal-overlay {
            position:fixed; inset:0; z-index:50;
            background:rgba(0,0,0,0.6); backdrop-filter:blur(8px);
            display:flex; align-items:center; justify-content:center;
            opacity:0; pointer-events:none; transition:opacity 0.3s;
        }
        .modal-overlay.open { opacity:1; pointer-events:all; }
        .modal-box {
            width:320px; padding:28px 24px;
            background:linear-gradient(145deg,rgba(255,255,255,0.18),rgba(255,255,255,0.07));
            border:1px solid rgba(255,255,255,0.28);
            border-radius:24px; backdrop-filter:blur(24px);
            box-shadow:0 24px 60px rgba(0,0,0,0.5), inset 0 2px 0 rgba(255,255,255,0.4);
            position:relative; overflow:hidden;
            transform:scale(0.92) translateY(16px); transition:transform 0.3s;
        }
        .modal-overlay.open .modal-box { transform:scale(1) translateY(0); }
        .modal-box::before {
            content:''; position:absolute;top:0;left:0;right:0;height:45%;
            background:linear-gradient(180deg,rgba(255,255,255,0.16),transparent);
            border-radius:24px 24px 0 0; pointer-events:none;
        }
        .modal-title {
            font-size:15px; font-weight:700; margin-bottom:4px;
            background:linear-gradient(135deg,#fff,#c4aaff);
            -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
        }
        .modal-sub { font-size:12px; color:rgba(255,255,255,0.4); margin-bottom:20px; letter-spacing:.5px; text-transform:uppercase; }

        /* Pill toggle */
        .pill-wrap {
            display:flex; background:rgba(0,0,0,0.3); border-radius:14px; padding:4px;
            border:1px solid rgba(255,255,255,0.12); margin-bottom:20px; position:relative;
        }
        .pill-slider {
            position:absolute; top:4px; bottom:4px;
            width:calc(50% - 4px); border-radius:10px;
            background:linear-gradient(135deg,#8844ff,#5500cc);
            box-shadow:0 4px 16px rgba(120,60,255,0.5), inset 0 1px 0 rgba(255,255,255,0.3);
            transition:transform 0.25s cubic-bezier(0.16,1,0.3,1);
            pointer-events:none;
        }
        .pill-option {
            flex:1; padding:9px 4px; text-align:center; font-size:13px; font-weight:600;
            cursor:pointer; border-radius:10px; transition:color 0.2s; position:relative; z-index:1;
            color:rgba(255,255,255,0.5); user-select:none;
        }
        .pill-option.active { color:#fff; }

        /* Modal buttons */
        .modal-actions { display:flex; gap:10px; }
        .btn-modal-confirm {
            flex:1; padding:11px; border:none; border-radius:12px;
            font-family:'Inter',sans-serif; font-size:14px; font-weight:700;
            background:linear-gradient(180deg,#b870ff,#7020cc); color:#fff;
            cursor:pointer; position:relative; overflow:hidden; transition:all 0.2s;
            box-shadow:0 4px 16px rgba(140,60,220,0.4);
        }
        .btn-modal-confirm::before {
            content:''; position:absolute;top:0;left:0;right:0;height:50%;
            background:linear-gradient(180deg,rgba(255,255,255,0.3),transparent);
            border-radius:12px 12px 0 0;
        }
        .btn-modal-confirm:hover { filter:brightness(1.1); transform:translateY(-1px); }
        .btn-modal-cancel {
            padding:11px 18px; border-radius:12px;
            font-family:'Inter',sans-serif; font-size:14px; font-weight:500;
            background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.18);
            color:rgba(255,255,255,0.6); cursor:pointer; transition:all 0.2s;
        }
        .btn-modal-cancel:hover { background:rgba(255,255,255,0.13); color:#fff; }

        /* ── Toast ── */
        .toast {
            position:fixed; bottom:28px; left:50%;
            transform:translateX(-50%) translateY(80px);
            padding:11px 24px; border-radius:40px; font-size:13px; font-weight:600;
            backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,0.2);
            box-shadow:0 8px 32px rgba(0,0,0,0.4); opacity:0; z-index:100;
            transition:all 0.4s cubic-bezier(0.16,1,0.3,1); white-space:nowrap;
        }
        .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
        .toast.success { background:rgba(0,180,100,0.9); color:#fff; }
        .toast.error   { background:rgba(200,40,40,0.9);  color:#fff; }

        /* ── Responsividade mobile (375px) ── */
        @media (max-width: 640px) {
            body { padding: 12px; }
            .content { height: auto; min-height: 100vh; }
            .header { padding: 12px 16px; margin-bottom: 14px; }
            .header h1 { font-size: 15px; }
            .header-left { gap: 8px; flex-wrap: wrap; }
            .logo { height: 36px; }
            .nav-dash { font-size: 12px; padding: 6px 12px; }

            /* Colunas empilham verticalmente */
            .kanban-board {
                flex-direction: column;
                overflow-x: hidden;
                overflow-y: visible;
                height: auto;
                gap: 12px;
            }
            .kanban-col { flex: none; width: 100%; }
            .cards { max-height: 420px; }
            .kanban-col.collapsed .cards { max-height: 0; }

            .kcard { padding: 12px; }
            .modal-box { width: calc(100vw - 32px); padding: 22px 18px; }
        }
    </style>
</head>
<body>
    <div class="bg"></div>
    <div class="grid-lines"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="content">

        <!-- Header -->
        <div class="header">
            <div class="header-left">
                <img src="/assets/MSN-ICON.png" alt="Logo" class="logo">
                <h1>Kanban da Cozinha</h1>
                <a href="/dashboard" class="nav-dash">← Dashboard</a>
            </div>
            <div class="export-wrap">
                <button class="btn-export" id="btnExportToggle">📊 Exportar <span class="chevron">▾</span></button>
                <div class="export-menu" id="exportMenu">
                    <a href="/admin/export" class="export-option">📄 CSV (.csv)</a>
                    <a href="/admin/export/xlsx" class="export-option">📊 Excel (.xlsx)</a>
                </div>
            </div>
        </div>

        <!-- Board -->
        <div class="kanban-board">

            <% const colConfig = {
                Aberto:   { icon: '📥', cls: 'col-aberto' },
                Cozinha:  { icon: '🍳', cls: 'col-cozinha' },
                Entrega:  { icon: '🛵', cls: 'col-entrega' },
                Entregue: { icon: '✅', cls: 'col-entregue' }
            }; %>

            <% ['Aberto','Cozinha','Entrega','Entregue'].forEach(status => {
                const cfg = colConfig[status];
                const orders = columns[status];
            %>
            <div class="kanban-col" data-status="<%= status %>">

                <div class="col-header <%= cfg.cls %>" onclick="toggleCol(this)">
                    <span class="col-icon"><%= cfg.icon %></span>
                    <span class="col-title"><%= status %></span>
                    <span class="col-count"><%= orders.length %></span>
                    <button class="col-toggle" title="Recolher/Expandir" onclick="event.stopPropagation();toggleCol(this.closest('.col-header'))">
                        <span class="chevron">▼</span>
                    </button>
                </div>

                <div class="cards" id="col-<%= status.toLowerCase() %>">
                    <% if (orders.length === 0) { %>
                        <div class="empty-col">Nenhum pedido aqui</div>
                    <% } %>
                    <% orders.forEach(order => { %>
                        <div class="kcard" data-id="<%= order.id %>" data-status="<%= status %>">
                            <div class="kcard-id">Pedido #<%= order.id %></div>
                            <div class="kcard-name"><%= order.customer_name %></div>
                            <span class="kcard-size"><%= order.size %></span>
                            <div class="kcard-items"><%= order.itens || 'Sem ingredientes' %></div>
                            <% if (status === 'Entregue') { %>
                                <div class="kcard-delivered">
                                    <strong><%= order.delivered_to %></strong> —
                                    <%= new Date(order.delivered_at).toLocaleString('pt-BR', {day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) %>
                                </div>
                            <% } else { %>
                                <button class="btn-advance" data-id="<%= order.id %>" data-status="<%= status %>">
                                    <%= status === 'Entrega' ? '📦 Finalizar Entrega' : 'Avançar →' %>
                                </button>
                            <% } %>
                        </div>
                    <% }) %>
                </div>

            </div>
            <% }) %>

        </div>
    </div>

    <!-- Modal para Entrega → Entregue -->
    <div class="modal-overlay" id="modal">
        <div class="modal-box">
            <div class="modal-title">Finalizar Entrega</div>
            <div class="modal-sub">Entregue ao pedido #<span id="modalOrderId"></span></div>

            <div class="pill-wrap">
                <div class="pill-slider" id="pillSlider"></div>
                <div class="pill-option active" id="optCliente">Cliente</div>
                <div class="pill-option" id="optEntregador">ao Entregador</div>
            </div>

            <div class="modal-actions">
                <button class="btn-modal-confirm" id="btnConfirm">Confirmar</button>
                <button class="btn-modal-cancel" id="btnCancel">Cancelar</button>
            </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
        // ── Dropdown Exportar ──
        const btnExportToggle = document.getElementById('btnExportToggle');
        const exportMenu      = document.getElementById('exportMenu');
        btnExportToggle.addEventListener('click', e => {
            e.stopPropagation();
            const open = exportMenu.classList.toggle('open');
            btnExportToggle.classList.toggle('open', open);
        });
        document.addEventListener('click', () => {
            exportMenu.classList.remove('open');
            btnExportToggle.classList.remove('open');
        });

        // ── Toast ──
        function showToast(msg, type) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.className = 'toast ' + type;
            requestAnimationFrame(() => t.classList.add('show'));
            setTimeout(() => t.classList.remove('show'), 3200);
        }

        // ── Pill toggle ──
        let selectedDeliveredTo = 'Cliente';
        const pillSlider = document.getElementById('pillSlider');
        const optCliente = document.getElementById('optCliente');
        const optEntregador = document.getElementById('optEntregador');

        optCliente.addEventListener('click', () => {
            selectedDeliveredTo = 'Cliente';
            pillSlider.style.transform = 'translateX(0)';
            optCliente.classList.add('active');
            optEntregador.classList.remove('active');
        });
        optEntregador.addEventListener('click', () => {
            selectedDeliveredTo = 'ao Entregador';
            pillSlider.style.transform = 'translateX(100%)';
            optEntregador.classList.add('active');
            optCliente.classList.remove('active');
        });

        // ── Modal ──
        let pendingOrderId = null;
        const modal = document.getElementById('modal');

        function openModal(orderId) {
            pendingOrderId = orderId;
            document.getElementById('modalOrderId').textContent = orderId;
            // Reset pill
            selectedDeliveredTo = 'Cliente';
            pillSlider.style.transform = 'translateX(0)';
            optCliente.classList.add('active');
            optEntregador.classList.remove('active');
            modal.classList.add('open');
        }

        document.getElementById('btnCancel').addEventListener('click', () => {
            modal.classList.remove('open');
            pendingOrderId = null;
        });
        modal.addEventListener('click', e => {
            if (e.target === modal) { modal.classList.remove('open'); pendingOrderId = null; }
        });

        document.getElementById('btnConfirm').addEventListener('click', async () => {
            if (!pendingOrderId) return;
            modal.classList.remove('open');
            await doAdvance(pendingOrderId, selectedDeliveredTo);
            pendingOrderId = null;
        });

        // ── Avançar pedido ──
        async function doAdvance(orderId, deliveredTo = null) {
            try {
                const body = new URLSearchParams({ order_id: orderId });
                if (deliveredTo) body.append('delivered_to', deliveredTo);

                const res = await fetch('/orders/advance', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                });
                const data = await res.json();

                if (!data.success) {
                    showToast(data.message || 'Erro ao avançar pedido.', 'error');
                    return;
                }

                // Anima e move o card para a próxima coluna
                const card = document.querySelector(`.kcard[data-id="${orderId}"]`);
                const nextColCards = document.querySelector(`.kanban-col[data-status="${data.nextStatus}"] .cards`);

                card.style.opacity = '0';
                card.style.transform = 'scale(0.9) translateY(-10px)';

                setTimeout(() => {
                    // Atualiza o card para o novo status
                    card.dataset.status = data.nextStatus;

                    // Remove ou atualiza o botão
                    const btn = card.querySelector('.btn-advance');
                    if (data.nextStatus === 'Entregue') {
                        if (btn) btn.remove();
                        // Adiciona info de entrega
                        const info = document.createElement('div');
                        info.className = 'kcard-delivered';
                        info.innerHTML = `<strong>${deliveredTo}</strong> — agora`;
                        card.appendChild(info);
                    } else {
                        if (btn) {
                            btn.dataset.status = data.nextStatus;
                            btn.textContent = data.nextStatus === 'Entrega' ? '📦 Finalizar Entrega' : 'Avançar →';
                        }
                    }

                    // Remove empty-col se existir
                    const emptyMsg = nextColCards.querySelector('.empty-col');
                    if (emptyMsg) emptyMsg.remove();

                    nextColCards.prepend(card);
                    updateColCounts();

                    requestAnimationFrame(() => {
                        card.style.opacity = '1';
                        card.style.transform = 'scale(1) translateY(0)';
                    });

                    showToast(`Pedido #${orderId} → ${data.nextStatus}`, 'success');
                }, 350);

            } catch {
                showToast('Erro de conexão.', 'error');
            }
        }

        // ── Click nos botões de avanço ──
        document.addEventListener('click', e => {
            const btn = e.target.closest('.btn-advance');
            if (!btn) return;
            const orderId = btn.dataset.id;
            const status = btn.dataset.status;
            if (status === 'Entrega') {
                openModal(orderId);
            } else {
                doAdvance(orderId);
            }
        });

        // ── Atualiza contadores das colunas ──
        function updateColCounts() {
            document.querySelectorAll('.kanban-col').forEach(col => {
                const count = col.querySelectorAll('.kcard').length;
                col.querySelector('.col-count').textContent = count;
            });
        }

        // ── Recolher/expandir coluna ──
        function toggleCol(header) {
            const col = header.closest('.kanban-col');
            col.classList.toggle('collapsed');
            const chevron = header.querySelector('.chevron');
            if (chevron) chevron.textContent = col.classList.contains('collapsed') ? '▶' : '▼';
        }
    </script>
</body>
</html>
